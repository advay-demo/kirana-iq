# Production Environment Variables

# The secret key for Django. Generate a secure random string for production.
SECRET_KEY=your_secure_random_secret_key_here

# Set to False in production
DEBUG=False

# Your production domain names separated by commas
ALLOWED_HOSTS=api.kiranaiq.com,kiranaiq.onrender.com

# Your PostgreSQL Database URL provided by Render or another host
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# The exact URL of your Vercel frontend so it can access the API
CORS_ALLOWED_ORIGINS=https://kiranaiq.vercel.app,https://www.kiranaiq.com

# External APIs
GOOGLE_MAPS_API_KEY=your_google_maps_key
GEMINI_API_KEY=your_gemini_api_key
